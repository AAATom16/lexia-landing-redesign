# Postgres connection (Railway will inject DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexia?schema=public

# Long random secret used for JWT signing. Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed web origins
CORS_ORIGINS=http://localhost:5173,https://lexia-landing-redesign.up.railway.app

# Port the API listens on (Railway injects PORT automatically)
PORT=3001

NODE_ENV=development
