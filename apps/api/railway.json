{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile=false && pnpm --filter @lexia/api db:generate && pnpm --filter @lexia/api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @lexia/api db:migrate && pnpm --filter @lexia/api start",
    "restartPolicyType": "ON_FAILURE",
    "healthcheckPath": "/healthz",
    "healthcheckTimeout": 30
  }
}
