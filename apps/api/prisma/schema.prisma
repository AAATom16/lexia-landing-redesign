generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DISTRIBUTOR
  ADMIN
}

enum DistributorType {
  SZ_PM
  SZ_PA
  DJ
  VZ
  DPZ
  TIPAR
}

enum DraftStatus {
  DRAFT
  SENT_TO_CLIENT
  SIGNED
  CANCELLED
}

enum DraftSource {
  PUBLIC
  DISTRIBUTOR
  CRM
}

enum LegalCaseStatus {
  REGISTROVANO
  V_SETRENI
  KRYTO
  ZAMITNUTO
  UKONCENO
}

enum LegalCaseModel {
  TELEFONICKA_PORADA
  SAMOREGULACE
  EXTERNI_LIKVIDACE
}

enum DenialReason {
  PRED_POJISTENIM
  CEKACI_DOBA
  PROMLCENO
  MIMO_VECNY_ROZSAH
  VYLUKA
  NESPADA_DO_PILIRE
  JINE
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  passwordHash    String
  role            UserRole         @default(CUSTOMER)
  distributorType DistributorType?
  ico             String?
  parentId        String?
  parent          User?            @relation("DistributorTree", fields: [parentId], references: [id])
  children        User[]           @relation("DistributorTree")
  inheritCommissions Boolean       @default(false)
  brokerPool      String?
  drafts          ContractDraft[]
  auditLogs       AuditLog[]
  createdCases    LegalCase[] @relation("LegalCaseCreator")
  assignedCases   LegalCase[] @relation("LegalCaseAssignee")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([role])
  @@index([parentId])
}

model ContractDraft {
  id               String      @id @default(cuid())
  number           String?     @unique
  createdById      String
  createdBy        User        @relation(fields: [createdById], references: [id])
  source           DraftSource
  status           DraftStatus @default(DRAFT)
  productCode      String
  clientName       String?
  clientEmail      String?
  clientIco        String?
  pillars          String[]
  segment          String?
  territorialScope String      @default("CZ")
  commissionModel  Int?
  premiumMonthly   Int
  premiumYearly    Int
  inputJson        Json
  resultJson       Json
  notes            String?
  legalCases       LegalCase[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([createdById])
  @@index([status])
  @@index([source])
}

model LegalCase {
  id              String          @id @default(cuid())
  caseNumber      String          @unique
  contractDraftId String?
  contractDraft   ContractDraft?  @relation(fields: [contractDraftId], references: [id])
  // Pojistník + nahlašovatel
  policyholderName  String
  policyholderEmail String?
  policyholderIco   String?
  isVip             Boolean       @default(false)
  reporterName      String?
  reporterPhone     String?
  // Pojistné krytí
  productCode     String
  pillarCode      String
  legalAreaCode   String?
  claimType       String?
  // Časové údaje
  caseDate        DateTime        // Datum vzniku případu
  reportedDate    DateTime        @default(now())
  policyStart     DateTime?
  // Stav a model
  status          LegalCaseStatus @default(REGISTROVANO)
  model           LegalCaseModel  @default(SAMOREGULACE)
  isTelefonicka   Boolean         @default(false)
  // Finanční údaje (Kč, integers)
  reserveExternal Int             @default(0)
  reserveInternal Int             @default(0)
  paidExternal    Int             @default(0)
  paidInternal    Int             @default(0)
  // Popis + zamítnutí
  description     String?
  denialReason    DenialReason?
  denialNote      String?
  // Audit
  createdById     String?
  createdBy       User?           @relation("LegalCaseCreator", fields: [createdById], references: [id])
  assigneeId      String?
  assignee        User?           @relation("LegalCaseAssignee", fields: [assigneeId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([policyholderEmail])
  @@index([status])
  @@index([contractDraftId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}
