generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DISTRIBUTOR
  ADMIN
}

enum DistributorType {
  SZ_PM
  SZ_PA
  DJ
  VZ
  DPZ
  TIPAR
}

enum DraftStatus {
  DRAFT
  SENT_TO_CLIENT
  SIGNED
  CANCELLED
}

enum DraftSource {
  PUBLIC
  DISTRIBUTOR
  CRM
  PARTNER_API
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  TERMINATED
}

enum SalespersonStatus {
  ACTIVE
  INACTIVE
}

enum DiscountKind {
  PERMANENT
  ONE_TIME
}

enum DiscountStatus {
  ACTIVE
  EXHAUSTED
  EXPIRED
  REVOKED
}

enum WebhookEvent {
  DRAFT_CREATED
  DRAFT_SENT_TO_CLIENT
  DRAFT_SIGNED
  DRAFT_CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  DEAD
}

enum CommissionStatus {
  PENDING_PAYOUT
  INCLUDED_IN_PAYOUT
  PAID
  CANCELLED
}

enum PayoutStatus {
  DRAFT
  READY_TO_PAY
  PAID
  CANCELLED
}

enum LegalCaseStatus {
  REGISTROVANO
  V_SETRENI
  KRYTO
  ZAMITNUTO
  UKONCENO
}

enum LegalCaseModel {
  TELEFONICKA_PORADA
  SAMOREGULACE
  EXTERNI_LIKVIDACE
}

enum DenialReason {
  PRED_POJISTENIM
  CEKACI_DOBA
  PROMLCENO
  MIMO_VECNY_ROZSAH
  VYLUKA
  NESPADA_DO_PILIRE
  JINE
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  passwordHash    String
  role            UserRole         @default(CUSTOMER)
  distributorType DistributorType?
  ico             String?
  parentId        String?
  parent          User?            @relation("DistributorTree", fields: [parentId], references: [id])
  children        User[]           @relation("DistributorTree")
  inheritCommissions Boolean       @default(false)
  brokerPool      String?
  drafts          ContractDraft[]
  auditLogs       AuditLog[]
  createdCases    LegalCase[] @relation("LegalCaseCreator")
  assignedCases   LegalCase[] @relation("LegalCaseAssignee")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([role])
  @@index([parentId])
}

model ContractDraft {
  id               String      @id @default(cuid())
  number           String?     @unique
  createdById      String
  createdBy        User        @relation(fields: [createdById], references: [id])
  source           DraftSource
  status           DraftStatus @default(DRAFT)
  productCode      String
  clientName       String?
  clientEmail      String?
  clientIco        String?
  pillars          String[]
  segment          String?
  territorialScope String      @default("CZ")
  commissionModel  Int?
  premiumMonthly   Int
  premiumYearly    Int
  inputJson        Json
  resultJson       Json
  notes            String?
  // Partner API attribution
  partnerId        String?
  partner          Partner?       @relation(fields: [partnerId], references: [id])
  salespersonId    String?
  salesperson      Salesperson?   @relation(fields: [salespersonId], references: [id])
  discountCodeId   String?
  discountCode     DiscountCode?  @relation(fields: [discountCodeId], references: [id])
  discountSnapshot Json?
  partnerRefId     String?
  signedAt         DateTime?
  cancelledAt      DateTime?
  legalCases       LegalCase[]
  commissions      CommissionEntry[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([createdById])
  @@index([status])
  @@index([source])
  @@index([partnerId])
  @@index([salespersonId])
}

model Partner {
  id                            String        @id @default(cuid())
  brokerCode                    String        @unique
  name                          String
  ico                           String?
  contactEmail                  String
  contactPhone                  String?
  commissionModel               Int           @default(1)
  commissionRateZiskatelska     Int?
  commissionRateNasledna        Int?
  commissionRatePrubezna        Int?
  status                        PartnerStatus @default(ACTIVE)
  contractedAt                  DateTime?
  salespeople                   Salesperson[]
  apiKeys                       ApiKey[]
  discountCodes                 DiscountCode[]
  drafts                        ContractDraft[]
  webhooks                      Webhook[]
  commissions                   CommissionEntry[]
  payouts                       Payout[]
  createdAt                     DateTime      @default(now())
  updatedAt                     DateTime      @updatedAt

  @@index([brokerCode])
  @@index([status])
}

model Webhook {
  id          String              @id @default(cuid())
  partnerId   String
  partner     Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  url         String
  secret      String
  events      WebhookEvent[]
  enabled     Boolean             @default(true)
  deliveries  WebhookDelivery[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([partnerId])
}

model WebhookDelivery {
  id                 String                @id @default(cuid())
  webhookId          String
  webhook            Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event              WebhookEvent
  payload            Json
  signature          String
  status             WebhookDeliveryStatus @default(PENDING)
  attempts           Int                   @default(0)
  lastResponseStatus Int?
  lastResponseBody   String?
  scheduledAt        DateTime              @default(now())
  deliveredAt        DateTime?
  createdAt          DateTime              @default(now())

  @@index([status, scheduledAt])
  @@index([webhookId])
}

model CommissionEntry {
  id              String   @id @default(cuid())
  partnerId       String
  partner         Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  contractDraftId String
  contractDraft   ContractDraft @relation(fields: [contractDraftId], references: [id], onDelete: Cascade)
  model           Int
  kind            String                                  // "ziskatelska" | "nasledna" | "prubezna"
  yearlyPremium   Int
  percent         Int
  amount          Int
  notes           String?
  status          CommissionStatus @default(PENDING_PAYOUT)
  payoutId        String?
  payout          Payout?  @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([partnerId])
  @@index([contractDraftId])
  @@index([payoutId])
  @@index([status])
}

model Payout {
  id           String            @id @default(cuid())
  partnerId    String
  partner      Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  reference    String            @unique
  periodFrom   DateTime
  periodTo     DateTime
  totalAmount  Int
  entriesCount Int               @default(0)
  status       PayoutStatus      @default(DRAFT)
  paidAt       DateTime?
  paymentNote  String?
  entries      CommissionEntry[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([partnerId])
  @@index([status])
}

model Salesperson {
  id              String            @id @default(cuid())
  partnerId       String
  partner         Partner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  salespersonCode String            @unique
  name            String
  email           String?
  phone           String?
  cnbReg          String?
  cnbCategory     DistributorType?
  status          SalespersonStatus @default(ACTIVE)
  drafts          ContractDraft[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([partnerId, salespersonCode])
  @@index([partnerId])
}

model ApiKey {
  id              String              @id @default(cuid())
  partnerId       String
  partner         Partner             @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  prefix          String              @unique
  hash            String
  label           String
  scopes          String[]
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime            @default(now())
  idempotencyKeys IdempotencyRecord[]

  @@index([partnerId])
}

model IdempotencyRecord {
  id             String   @id @default(cuid())
  apiKeyId       String
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  key            String
  payloadHash    String
  responseStatus Int
  responseBody   Json
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@unique([apiKeyId, key])
  @@index([expiresAt])
}

model DiscountCode {
  id          String          @id @default(cuid())
  partnerId   String
  partner     Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  code        String          @unique
  label       String
  kind        DiscountKind
  percent     Int
  validFrom   DateTime?
  validUntil  DateTime?
  maxUses     Int?
  usedCount   Int             @default(0)
  status      DiscountStatus  @default(ACTIVE)
  drafts      ContractDraft[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([code])
  @@index([partnerId])
}

model LegalCase {
  id              String          @id @default(cuid())
  caseNumber      String          @unique
  contractDraftId String?
  contractDraft   ContractDraft?  @relation(fields: [contractDraftId], references: [id])
  // Pojistník + nahlašovatel
  policyholderName  String
  policyholderEmail String?
  policyholderIco   String?
  isVip             Boolean       @default(false)
  reporterName      String?
  reporterPhone     String?
  // Pojistné krytí
  productCode     String
  pillarCode      String
  legalAreaCode   String?
  claimType       String?
  // Časové údaje
  caseDate        DateTime        // Datum vzniku případu
  reportedDate    DateTime        @default(now())
  policyStart     DateTime?
  // Stav a model
  status          LegalCaseStatus @default(REGISTROVANO)
  model           LegalCaseModel  @default(SAMOREGULACE)
  isTelefonicka   Boolean         @default(false)
  // Finanční údaje (Kč, integers)
  reserveExternal Int             @default(0)
  reserveInternal Int             @default(0)
  paidExternal    Int             @default(0)
  paidInternal    Int             @default(0)
  // Popis + zamítnutí
  description     String?
  denialReason    DenialReason?
  denialNote      String?
  // Audit
  createdById     String?
  createdBy       User?           @relation("LegalCaseCreator", fields: [createdById], references: [id])
  assigneeId      String?
  assignee        User?           @relation("LegalCaseAssignee", fields: [assigneeId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([policyholderEmail])
  @@index([status])
  @@index([contractDraftId])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  action      String
  entityType  String
  entityId    String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}
