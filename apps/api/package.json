{
  "name": "@lexia/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @lexia/domain build && prisma generate && tsx watch src/server.ts",
    "build": "pnpm --filter @lexia/domain build && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "@hono/zod-validator": "0.4.1",
    "@lexia/domain": "workspace:*",
    "@prisma/client": "5.22.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.10.2",
    "bcryptjs": "2.4.3",
    "hono": "4.6.13",
    "jose": "5.9.6",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "zod": "3.24.1"
  }
}
